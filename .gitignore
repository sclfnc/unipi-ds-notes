# ── Root of the monorepo. The *-notes/ folders are git submodules ──
# ── (pinned via .gitmodules), NOT ignored. This file ignores only ──
# ── root-level cruft, not the submodules and not the canonical files ──
# ── (main.tex, src/, .latexmkrc, README.md, CLAUDE.md, .claude/).   ──

# LaTeX build artifacts (only if the root main.tex is ever compiled)
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.log
*.out
*.run.xml
*.synctex.gz
*.synctex(busy)
*.toc
*.xdv
texput.*

# Assistant config: track the shared skills, ignore local session state.
# (.claude/ is ignored by the user's global gitignore; skills are force-tracked.)
.claude/*
!.claude/skills/

# OS / editor cruft
.directory
.vscode/
.DS_Store
Thumbs.db
*~
